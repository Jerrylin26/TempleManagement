    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    <link rel="stylesheet" href="~/css/FollowerList/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/FollowerList/bootstrap.min.css.map" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/FollowerList/owl.carousel.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/FollowerList/style.css" asp-append-version="true" />
}
@model List<TempleManagement.Models.BasicInfo>
<body>

    <div class="content">
        <button class="button-25" id="modify_button" role="button"> 檢視個人資料</button>
        <div class="container">
            <h2 class="mb-5">信徒清冊</h2>
            <div class="dropdown">
                <button class="btn btn-secondary dropdown-toggle" type="button" id="dropdownMenuButton1" data-bs-toggle="dropdown" aria-expanded="false">
                    篩選
                </button>
                <ul class="dropdown-menu" aria-labelledby="dropdownMenuButton1">
                    <li><a class="dropdown-item" href="#">個人編號</a></li>
                    <li><a class="dropdown-item" href="#">僅戶長</a></li>
                    <li><a class="dropdown-item" href="#">信徒類別</a></li>
                    <li><a class="dropdown-item" href="#">戶籍縣市</a></li>
                    <li><a class="dropdown-item" href="#">通訊縣市</a></li>
                    <li><a class="dropdown-item" href="#">生肖</a></li>
                    <li><a class="dropdown-item" href="#">性別</a></li>
                    <li><a class="dropdown-item" href="#">年齡</a></li>
                </ul>
            </div>

            <div class="table-responsive">

                <table class="table table-striped custom-table">
                    <thead>
                        <tr>

                            <th scope="col">信徒編號</th>
                            <th scope="col">姓名</th>
                            <th scope="col">性別</th>
                            <th scope="col">年齡</th>
                            <th scope="col">生肖</th>
                            <th scope="col"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null)
                        {
                            @foreach (var item in  Model)
                            {
                                <tr scope="row">

                                    <td>
                                        @item.MID
                                    </td>
                                    <td class="pl-0">
                                        <!--
                                            <div class="d-flex align-items-center">
                                                <label class="custom-control ios-switch">
                                                    <input type="checkbox" class="ios-switch-control-input" checked="">
                                                    <span class="ios-switch-control-indicator"></span>
                                                </label>

                                                <a href="#">@item.Name</a>
                                            </div>
                                        -->
                                        @item.Name
                                    </td>
                                    <td>
                                        @if (item.Sex == true)
                                        {
                                            @:男
                                        }
                                        else
                                        {
                                            @:女
                                        } 
                                    </td>
                                    <td>@item.Age</td>
                                    <td>@item.Zodiac</td>
                                    <td><a href="#" data-mid="@item.MID" class="more">Details</a></td>

                                </tr>
                            }
                        }

                    </tbody>
                </table>
            </div>


        </div>

    </div>


    

</body>



<div id="updateModal" class="modal fade">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">詳細資料</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" id="modalBody">
                <!--  PartialView 會塞進來 -->
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <!-- 解決post2次問題-->
                <button type="button"
                        class="btn btn-primary"
                        id="btn_post">

                    確定
                </button>
            </div>

        </div>
    </div>
</div>


<script src="~/lib/jquery/dist/jquery.min.js"></script>

<script>
    $('#modify_button').on('click', function () {

        $.get('/FollowerList/ShowOption', function (html) {

            // 把 PartialView 塞進 Modal
            $('#modalBody').html(html);

            // 開啟 Modal
            var modal = new bootstrap.Modal(document.getElementById('updateModal'));
            modal.show();
        });

    });
</script>

<script>
    $(document).on("click", ".more", function (e) {
        e.preventDefault();

        let mid = $(this).data("mid"); // ⭐ 這裡拿到 mid

        $.ajax({
            url: "/FollowerList/Detail",
            type: "GET",
            data: { mid: mid },  // ⭐ 送給 controller
            success: function (result) {

                $('#modalBody').html(result);
                var modal = new bootstrap.Modal(document.getElementById("updateModal"));

                modal.show();
            }
        });
    });
</script>
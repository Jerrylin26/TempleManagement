        e.preventDefault(); // ❗ 阻止傳統 submit（不跳頁）

        let formData = $(this).serialize(); // 取得 form 所有欄位
        alert(formData);
        $.ajax({
            type: "POST",
            url: "/DonateOperation/post_selected_option",
            data: formData,
            success: function (result) {
                console.log(result);
            },
            error: function (xhr) {
                alert("發生錯誤");
            }
        });

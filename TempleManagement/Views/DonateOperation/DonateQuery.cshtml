@{
    // <link rel="stylesheet" href="https:www.w3schools.com/w3css/5/w3.css">
    <link rel="stylesheet" href="~/css/DonateOperation/Index.css">
    <link rel="stylesheet" href="~/css/DonateOperation/w3.css"> //此為自行下載後的.css (w3css/5/w3.css)
}
@model DonationViewModel_DonateQuery ;

<div class="button_wrapper">
    <div class="dropdown">
        <button class="btn btn-secondary dropdown-toggle" type="button" id="DonateButton" data-bs-toggle="dropdown" aria-expanded="false">
            捐獻類別(戶)
        </button>
        <ul class="dropdown-menu" aria-labelledby="DonateButton">
            <li><a class="dropdown-item" href="#">大斗</a></li>
            <li><a class="dropdown-item" href="#">小斗</a></li>
            <li><a class="dropdown-item" href="#">平安燈</a></li>
            <li><a class="dropdown-item" href="#">安太歲</a></li>
        </ul>
    </div>

    <div class="dropdown">
        <button class="btn btn-secondary dropdown-toggle" type="button" id="DonateButton1" data-bs-toggle="dropdown" aria-expanded="false">
            捐獻類別(個人)
        </button>
        <ul class="dropdown-menu" aria-labelledby="DonateButton1">
            <li><a class="dropdown-item" href="#">光明燈(一) 600</a></li>
            <li><a class="dropdown-item" href="#">光明燈(二) 700</a></li>
            <li><a class="dropdown-item" href="#">光明燈(三) 800</a></li>
            <li><a class="dropdown-item" href="#">光明燈(四) 1000</a></li>
        </ul>
    </div>
</div>
<br />
<br />
<br />
<span id="btn_2">
    <button class="button-25" id="modify_button" role="button"> 新增捐獻</button>
</span>

<br />
<br />
<br />
<br />

<div id="Change_to_Donation_create">
    @foreach (var household in Model.DonateQuery)
    {
        <div style="font-size:30px;background-color:darksalmon">戶號: <span style="font-weight:bold;">@household.First().HouseID</span></div>

        <table class="w3-table-all w3-xlarge fixed-table">
            <colgroup>
                <col style="width: 10%;">
                <col style="width: 10%;">
                <col style="width: 10%;">
                <col style="width: 15%;">
                <col style="width: 10%;">
                <col style="width: 10%;">
                <col style="width: 15%;">
                <col style="width: 15%;">
            </colgroup>


            <tr>
                <th>安斗</th>
                <th>個人編號</th>
                <th>姓名</th>
                @foreach (var item in Model.DonateType.GroupBy(x => x.Prototype).Where(x => x.Key != 1))
                {
                    <th>@item.First().Prototype_name</th>
                }
                <th>總捐獻(價格)</th>
                <th>備註</th>
            </tr>

            @foreach (var member in household)
            {
                <tr>
                    <td>
                        @if (member.Donate_item?.Any(x => x.DonateTypeId <= 2) ?? false)
                        {
                            <input checked="" class="check_dipper" type="checkbox" disabled>
                            <span>@member.Donate_item.Where(x => x.DonateTypeId <= 2).FirstOrDefault()?.Name_chinese</span>
                        }
                        else
                        {
                            <input class="no_check_dipper" type="checkbox">
                            <span>無</span>
                        }



                    </td>
                    <td>
                        <div>@member.Member_number</div>
                    </td>
                    <td>
                        <div>@member.Name</div>
                        @if (member.Is_head == true)
                        {
                            <div style="background-color:aquamarine">戶長</div>
                        }
                    </td>

                    @foreach (var type in Model.DonateType.GroupBy(g => g.Prototype).Where(x => x.Key != 1))
                    {
                        <td>
                            <div>@type.First().Prototype_name</div>
                            
                            @foreach (var item in type)
                            {
                                @if (member.Donate_item.Any(x => x.DonateTypeId == item.ID))
                                {
                                    <div>@item.Price</div>
                                }
                                
                            }

                        </td>
                    }

                    <td>
                        
                        @if (member.Is_head == true)
                        {
                            <div>@(member.Donate_item?.Sum(x => x.SelectedPrice) ?? 0)</div>
                            
                            if (member.Is_dipper)
                            {
                                <div>(@member.Donate_item.Where(x => x.DonateTypeId<=2).First().Name_chinese :@member.Donate_item.Where(x => x.DonateTypeId<=2).First().SelectedPrice)</div>
                            }


                        }
                        else
                        {
                            <div>@(member.Donate_item.Where(x=>x.DonateTypeId>2).Sum(x => x.SelectedPrice))</div>
                        }

                    </td>
                    <td>
                        <textarea class="cell-edit-textarea">@member.Note</textarea>
                    </td>

                </tr>
            }
        </table>

        <br />


    }
</div>




<br /><br /><br />

<button class="button-24" role="button"> 確定送出</button>
<br />
<br />
<br />
<br />
<br />
<br />


<div id="updateModal" class="modal fade">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">新增捐獻</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" id="modalBody">
                <!--  PartialView 會塞進來 -->
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <!-- 解決poast2次問題-->
                <button type="button"
                        class="btn btn-primary"
                        id="btn_post">
                        
                    確定
                </button>
            </div>

        </div>
    </div>
</div>


<script src="~/lib/jquery/dist/jquery.min.js"></script>

<script>
    $('#modify_button').on('click', function () {

        $.get('/DonateOperation/ShowOption', function (html) {

            // 把 PartialView 塞進 Modal
            $('#modalBody').html(html);

            // 開啟 Modal
            var modal = new bootstrap.Modal(document.getElementById('updateModal'));
            modal.show();
        });

    });
</script>
    
